# Copy this file to .env and fill in your own values.
# The system works WITHOUT an API key (it falls back to a template-based
# explanation generator) - this is only needed to enable live AI-generated
# explanations from the Anthropic API.

GEMINI_API_KEY=AQ.Ab8RN6JIjFUkPweZQPk_laHeGzs4KLddykqMKhoRcZATk30UOQ

# Optional: change the Flask port
PORT=5000

# --- "Sign in with Google" + Google Sheets auto-sync ---
# Create these in Google Cloud Console > APIs & Services > Credentials
# (OAuth client ID, type "Web application"). Enable the Google Sheets API
# for the project too. Add GOOGLE_REDIRECT_URI below as an "Authorized
# redirect URI" on that OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
GOOGLE_POST_LOGIN_REDIRECT=http://localhost:5000/
FLASK_SECRET_KEY=
